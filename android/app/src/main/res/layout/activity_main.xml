<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬡ Claude Usage"
            android:textColor="#c084fc"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/planNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Claude Max"
            android:textColor="#888899"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Model usage cards (dynamically added) -->
        <LinearLayout
            android:id="@+id/modelsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/toggleButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Start Monitoring"
                android:backgroundTint="#c084fc"
                android:textColor="#ffffff"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/refreshButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Refresh"
                android:backgroundTint="#2a2a4a"
                android:textColor="#e0e0e0" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not connected"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#c084fc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Session Key"
            android:textColor="#888899"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="claude.ai → F12 → Application → Cookies → sessionKey"
            android:textColor="#555566"
            android:textSize="10sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/sessionKeyInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:textColor="#e0e0e0"
            android:textColorHint="#555566"
            android:hint="sk-ant-sid01-..."
            android:inputType="textPassword"
            android:padding="12dp"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/sessionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888899"
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Interval (seconds)"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/refreshInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:textColor="#e0e0e0"
            android:textColorHint="#555566"
            android:hint="120"
            android:inputType="number"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save Settings"
            android:backgroundTint="#2a2a4a"
            android:textColor="#c084fc" />

    </LinearLayout>
</ScrollView>
