<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬡ Claude Usage"
            android:textColor="#c084fc"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Cost Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💰 Cost"
                    android:textColor="#888899"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/budgetPercentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0%"
                    android:textColor="#e0e0e0"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/costText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="$0.00 / $100.00"
                android:textColor="#e0e0e0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/costBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="#2a2a4a" />
        </LinearLayout>

        <!-- Token Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊 Tokens"
                    android:textColor="#888899"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tokenPercentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0%"
                    android:textColor="#e0e0e0"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tokenText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 / 10M"
                android:textColor="#e0e0e0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/tokenBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="#2a2a4a"
                android:progressTint="#c084fc" />
        </LinearLayout>

        <!-- Detail -->
        <TextView
            android:id="@+id/detailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Input: 0   📤 Output: 0"
            android:textColor="#888899"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Period Breakdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usage by Period"
            android:textColor="#c084fc"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 5h period -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="⏱ 5h"
                android:textColor="#c084fc"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/period5hCost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$0.00"
                android:textColor="#e0e0e0"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/period5hDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 tok │ 0 reqs"
                android:textColor="#888899"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Daily period -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="📅 Day"
                android:textColor="#c084fc"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/periodDailyCost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$0.00"
                android:textColor="#e0e0e0"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/periodDailyDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 tok │ 0 reqs"
                android:textColor="#888899"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Weekly period -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="📆 Wk"
                android:textColor="#c084fc"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/periodWeeklyCost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$0.00"
                android:textColor="#e0e0e0"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/periodWeeklyDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 tok │ 0 reqs"
                android:textColor="#888899"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Monthly period -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="📋 Mo"
                android:textColor="#c084fc"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/periodMonthlyCost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$0.00"
                android:textColor="#e0e0e0"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/periodMonthlyDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 tok │ 0 reqs"
                android:textColor="#888899"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/toggleButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Start Monitoring"
                android:backgroundTint="#c084fc"
                android:textColor="#ffffff"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/refreshButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Refresh"
                android:backgroundTint="#2a2a4a"
                android:textColor="#e0e0e0" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not connected"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Settings Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#c084fc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server URL"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:textColor="#e0e0e0"
            android:textColorHint="#555566"
            android:hint="http://your-server:8490"
            android:inputType="textUri"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Interval (seconds)"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/refreshInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:textColor="#e0e0e0"
            android:textColorHint="#555566"
            android:hint="60"
            android:inputType="number"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save Settings"
            android:backgroundTint="#2a2a4a"
            android:textColor="#c084fc" />

    </LinearLayout>
</ScrollView>
