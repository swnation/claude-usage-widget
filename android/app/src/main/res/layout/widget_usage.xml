<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#DD1a1a2e"
    android:padding="12dp">

    <!-- 타이틀 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⬡ Claude"
        android:textColor="#c084fc"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- 현재 세션 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="세션"
        android:textColor="#888899"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <ProgressBar
            android:id="@+id/widgetSessionBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="#4ade80"
            android:progressBackgroundTint="#2a2a4a" />

        <TextView
            android:id="@+id/widgetSessionPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#e0e0e0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetSessionReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#888899"
        android:textSize="10sp"
        android:layout_marginBottom="6dp" />

    <!-- 주간 한도 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="주간"
        android:textColor="#888899"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ProgressBar
            android:id="@+id/widgetWeeklyBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="#c084fc"
            android:progressBackgroundTint="#2a2a4a" />

        <TextView
            android:id="@+id/widgetWeeklyPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#e0e0e0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
