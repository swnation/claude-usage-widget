<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#DD1a1a2e"
    android:padding="14dp">

    <!-- 헤더: 상태 + 플랜 이름 + 업데이트 시간 + 새로고침 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widgetStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widgetPlanName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Claude Max"
            android:textColor="#c084fc"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp" />

        <TextView
            android:id="@+id/widgetUpdateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#555566"
            android:textSize="10sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widgetRefreshBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="#888899"
            android:textSize="18sp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp" />
    </LinearLayout>

    <!-- 세션 행: 라벨 + 바 + 큰 퍼센트 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="1dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="세션"
            android:textColor="#888899"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/widgetSessionBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="#4ade80"
            android:progressBackgroundTint="#2a2a4a" />

        <TextView
            android:id="@+id/widgetSessionPercent"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#4ade80"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 세션 리셋 -->
    <TextView
        android:id="@+id/widgetSessionReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666677"
        android:textSize="10sp"
        android:paddingStart="40dp"
        android:layout_marginBottom="6dp" />

    <!-- 주간 행: 라벨 + 바 + 큰 퍼센트 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="1dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="주간"
            android:textColor="#888899"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/widgetWeeklyBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="#c084fc"
            android:progressBackgroundTint="#2a2a4a" />

        <TextView
            android:id="@+id/widgetWeeklyPercent"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#c084fc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 주간 리셋 -->
    <TextView
        android:id="@+id/widgetWeeklyReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666677"
        android:textSize="10sp"
        android:paddingStart="40dp" />
</LinearLayout>
